{
    "name": "cleargoal/laravel-multilingual-blog",
    "description": "Complete multilingual blog system with AI generation, RSS imports, and Filament admin",
    "keywords": [
        "laravel",
        "blog",
        "multilingual",
        "filament",
        "spatie",
        "ai",
        "rss",
        "translatable"
    ],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Volodymyr Yefremov",
            "email": "cleargoal01@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "spatie/laravel-translatable": "^6.0|^7.0",
        "spatie/laravel-sluggable": "^3.6",
        "spatie/laravel-medialibrary": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/phpstan": "^2.0",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0"
    },
    "suggest": {
        "filament/filament": "Required for admin panel integration (^4.0)",
        "anthropics/anthropic-sdk-php": "Required for AI content generation (^1.0)",
        "spatie/laravel-feed": "Required for RSS feed generation (^4.0)",
        "mews/purifier": "Recommended for advanced HTML sanitization (^3.3)"
    },
    "autoload": {
        "psr-4": {
            "Cleargoal\\Blog\\": "src/",
            "Cleargoal\\Blog\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Cleargoal\\Blog\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Cleargoal\\Blog\\BlogServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage",
        "test:unit": "vendor/bin/pest tests/Unit",
        "test:feature": "vendor/bin/pest tests/Feature"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
